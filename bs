            // ===== TESTS =====
            async function beginTests(e) {
                e.preventDefault();
                const checkboxes = document.querySelectorAll('#session-form input[type="checkbox"]:checked');
                const items = Array.from(checkboxes).map(cb => ({
                    id: parseInt(cb.value),
                    name: cb.dataset.name
                }));

                if (items.length === 0) {
                    alert('Select at least one item!', 'w');
                    return;
                }

                const intakeSelect = document.getElementById('intake-time');
                let timeSince = intakeSelect?.value || 'immediate';
                if (timeSince === 'custom') {
                    timeSince = document.getElementById('custom-intake-time')?.value || 'custom';
                }

                const notes = document.getElementById('session-notes')?.value || '';

                state.sessionMeta = {
                    items, timeSince, notes,
                    tags: [...state.sessionTags],
                    date: new Date().toISOString()
                };

                hideModal();
                $('#test-overlay').classList.add('on');

                await runReactionTest();
                await runMemoryTest();
                await runNumberTest();
                await runFocusTest();
                
                await saveSession();
                showResults();
            }

            function runReactionTest() {
                return new Promise(resolve => {
                    $('#test-phase').textContent = 'Test 1/4: Reaction Time';
                    const trials = [];
                    let count = 0;
                    const total = 5;
                    let phase = 'wait';
                    let start;

                    $('#test-area').innerHTML = `
                        <p style="color:var(--text2);margin-bottom:1rem;">Click when screen turns white</p>
                        <div class="react-area" id="react-box">Wait for white...</div>
                        <p style="color:var(--text2);margin-top:0.8rem;">Trial: <span id="trial-num">1</span>/${total}</p>
                        <div class="prog"><div class="prog-fill" style="width:0%"></div></div>`;

                    const box = $('#react-box');

                    function startTrial() {
                        box.className = 'react-area';
                        box.textContent = 'Wait for white...';
                        const delay = 800 + Math.random() * 2000;
                        setTimeout(() => {
                            if (phase !== 'testing') return;
                            box.classList.add('go');
                            box.textContent = 'NOW!';
                            start = Date.now();
                        }, delay);
                    }

                    box.addEventListener('click', () => {
                        if (phase !== 'testing') return;
                        if (box.classList.contains('go')) {
                            const rt = Date.now() - start;
                            trials.push(rt);
                            count++;
                            box.className = 'react-area';
                            box.style.background = 'var(--grey)';
                            box.style.borderColor = 'var(--text2)';
                            box.textContent = `${rt}ms`;
                            $('#trial-num').textContent = count;
                            $('.prog-fill').style.width = `${(count/total)*100}%`;

                            if (count >= total) {
                                state.testResults.reaction = {
                                    avg: Math.round(trials.reduce((a,b)=>a+b,0)/trials.length),
                                    best: Math.min(...trials),
                                    consistency: Math.round((1 - (Math.max(...trials)-Math.min(...trials))/(trials.reduce((a,b)=>a+b,0)/trials.length))*100)
                                };
                                $('#test-phase').textContent = '✓ Reaction test done!';
                                setTimeout(resolve, 800);
                            } else {
                                setTimeout(startTrial, 600);
                            }
                        } else if (!box.classList.contains('go') && box.style.background !== 'var(--grey)') {
                            box.textContent = 'Too early!';
                            setTimeout(startTrial, 1000);
                        }
                    });

                    phase = 'testing';
                    startTrial();
                });
            }

            function runMemoryTest() {
                return new Promise(resolve => {
                    $('#test-phase').textContent = 'Test 2/4: Memory Grid';
                    const size = 4;
                    const len = 6;
                    const pattern = new Set();
                    while (pattern.size < len) pattern.add(Math.floor(Math.random() * (size*size)));

                    $('#test-area').innerHTML = `
                        <p id="mem-msg" style="color:var(--text2);margin-bottom:1rem;">Memorize the pattern (2 sec)</p>
                        <div class="mem-grid" style="grid-template-columns:repeat(${size},55px);" id="mem-grid">
                            ${Array.from({length:size*size}, (_,i) => `<div class="mem-cell ${pattern.has(i)?'on':''}" data-idx="${i}"></div>`).join('')}
                        </div>
                        <p style="color:var(--text2);margin-top:0.8rem;">Found: <span id="mem-found">0</span>/${len}</p>
                        <div class="prog"><div class="prog-fill" style="width:0%"></div></div>`;

                    let correct = 0;
                    let wrong = 0;
                    let phase = 'memorize';

                    setTimeout(() => {
                        phase = 'recall';
                        $('#mem-msg').textContent = 'Click the tiles you remember';
                        $$('#mem-grid .mem-cell').forEach(c => c.classList.remove('on'));
                    }, 2000);

                    $('#mem-grid').addEventListener('click', (e) => {
                        if (phase !== 'recall') return;
                        const cell = e.target.closest('.mem-cell');
                        if (!cell) return;
                        const idx = parseInt(cell.dataset.idx);
                        
                        if (pattern.has(idx) && !cell.classList.contains('ok')) {
                            cell.classList.add('ok');
                            correct++;
                            $('#mem-found').textContent = correct;
                            $('.prog-fill').style.width = `${(correct/len)*100}%`;
                            if (correct >= len) {
                                state.testResults.memory = {
                                    score: Math.min(Math.round((correct/(correct+wrong))*20), 20),
                                    correct, mistakes: wrong
                                };
                                $('#test-phase').textContent = '✓ Memory test done!';
                                setTimeout(resolve, 800);
                            }
                        } else if (!cell.classList.contains('ok')) {
                            cell.classList.add('bad');
                            wrong++;
                            setTimeout(() => cell.classList.remove('bad'), 300);
                        }
                    });
                });
            }

            function runNumberTest() {
                return new Promise(resolve => {
                    $('#test-phase').textContent = 'Test 3/4: Number Recall';
                    let span = 4;

                    function showNumber() {
                        const num = Array.from({length: span}, () => Math.floor(Math.random()*10)).join('');
                        $('#test-area').innerHTML = `
                            <p style="color:var(--text2);margin-bottom:1rem;">Remember this number</p>
                            <div class="num-big">${num}</div>
                            <p style="color:var(--text2);">Digit Span: ${span}</p>`;

                        setTimeout(() => {
                            $('#test-area').innerHTML = `
                                <p style="color:var(--text2);margin-bottom:1rem;">Enter the number</p>
                                <input type="text" class="num-inp" id="num-inp" maxlength="${span}" autofocus>
                                <p style="color:var(--text2);margin-top:0.8rem;">Digit Span: ${span}</p>
                                <button class="btn" id="num-submit" style="margin-top:0.8rem;">Submit</button>`;

                            $('#num-submit').addEventListener('click', () => checkNumber(num));
                            $('#num-inp').addEventListener('keypress', (e) => {
                                if (e.key === 'Enter') checkNumber(num);
                            });
                        }, 2500);
                    }

                    function checkNumber(correct) {
                        const input = $('#num-inp')?.value;
                        if (input === correct && span < 10) {
                            span++;
                            alert('Correct! Increasing span...', 's');
                            showNumber();
                        } else {
                            state.testResults.number = { span: input === correct ? span : span - 1 };
                            $('#test-phase').textContent = '✓ Number recall done!';
                            resolve();
                        }
                    }

                    showNumber();
                });
            }

            function runFocusTest() {
                return new Promise(resolve => {
                    $('#test-phase').textContent = 'Test 4/4: Shape Focus';
                    const shapes = ['●','■','▲','◆'];
                    const target = shapes[Math.floor(Math.random()*shapes.length)];
                    let correct = 0;
                    let wrong = 0;
                    let round = 0;
                    const total = 10;

                    function makeGrid() {
                        const cells = [];
                        const tpos = Math.floor(Math.random()*9);
                        for (let i = 0; i < 9; i++) {
                            if (i === tpos) cells.push(target);
                            else {
                                let s;
                                do { s = shapes[Math.floor(Math.random()*shapes.length)]; }
                                while (s === target);
                                cells.push(s);
                            }
                        }
                        $('#test-area').innerHTML = `
                            <p style="color:var(--text2);margin-bottom:1rem;">Tap only: <span style="font-size:1.8rem;">${target}</span></p>
                            <div class="shape-grid">${cells.map(s => `<div class="shape-cell" data-shape="${s}">${s}</div>`).join('')}</div>
                            <p style="color:var(--text2);margin-top:0.8rem;">Round: <span id="focus-round">${round+1}</span>/${total}</p>
                            <div class="prog"><div class="prog-fill" style="width:${(round/total)*100}%"></div></div>`;

                        $$('.shape-cell').forEach(c => {
                            c.addEventListener('click', () => {
                                if (c.dataset.shape === target) {
                                    c.classList.add('good');
                                    correct++;
                                    round++;
                                    $('#focus-round').textContent = Math.min(round+1, total);
                                    $('.prog-fill').style.width = `${(round/total)*100}%`;
                                    if (round >= total) {
                                        state.testResults.focus = {
                                            accuracy: Math.round((correct/(correct+wrong))*100),
                                            correct, incorrect: wrong
                                        };
                                        $('#test-phase').textContent = '✓ Focus test done!';
                                        resolve();
                                    } else {
                                        setTimeout(makeGrid, 300);
                                    }
                                } else {
                                    c.classList.add('bad');
                                    wrong++;
                                    setTimeout(() => c.classList.remove('bad'), 400);
                                }
                            });
                        });
                    }

                    makeGrid();
                });
            }

            function calcOverall() {
                const r = state.testResults.reaction ? Math.max(0, Math.min(100, (300 - state.testResults.reaction.avg)/2)) : 0;
                const m = state.testResults.memory ? (state.testResults.memory.score/20)*100 : 0;
                const n = state.testResults.number ? (state.testResults.number.span/10)*100 : 0;
                const f = state.testResults.focus?.accuracy || 0;
                return Math.round((r+m+n+f)/4);
            }

            async function saveSession() {
                const session = {
                    ...state.sessionMeta,
                    reaction_avg: state.testResults.reaction?.avg,
                    reaction_best: state.testResults.reaction?.best,
                    reaction_consistency: state.testResults.reaction?.consistency,
                    memory_score: state.testResults.memory?.score,
                    number_span: state.testResults.number?.span,
                    focus_score: state.testResults.focus?.accuracy,
                    overall_score: calcOverall(),
                    item_names: state.sessionMeta.items.map(i => i.name).join(' + '),
                    item_ids: state.sessionMeta.items.map(i => i.id)
                };
                await dbAdd('sessions', session);
            }

            function showResults() {
                $('#test-overlay').classList.remove('on');
                const m = state.sessionMeta;
                const r = state.testResults;
                showModal(`
                    <h2>⬡ Session Complete!</h2>
                    <div style="margin:1rem 0;padding:1rem;background:var(--bg3);border-radius:8px;">
                        <h3>${esc(m.items.map(i=>i.name).join(' + '))}</h3>
                        ${m.timeSince ? `<p><strong>Time Since:</strong> ${m.timeSince}</p>` : ''}
                        ${m.tags?.length ? `<p><strong>Tags:</strong> ${m.tags.join(', ')}</p>` : ''}
                        ${m.notes ? `<p><strong>Notes:</strong> ${esc(m.notes)}</p>` : ''}
                    </div>
                    <div class="grid2">
                        <div class="stat"><div class="stat-val" style="font-size:1.6rem;">${r.reaction?.avg||'--'}ms</div><div class="stat-lbl">Reaction</div></div>
                        <div class="stat"><div class="stat-val" style="font-size:1.6rem;">${r.memory?.score||'--'}/20</div><div class="stat-lbl">Memory</div></div>
                        <div class="stat"><div class="stat-val" style="font-size:1.6rem;">${r.number?.span||'--'}</div><div class="stat-lbl">Digit Span</div></div>
                        <div class="stat"><div class="stat-val" style="font-size:1.6rem;">${r.focus?.accuracy||'--'}%</div><div class="stat-lbl">Focus</div></div>
                    </div>
                    <div style="text-align:center;margin:1.5rem 0;padding:1.5rem;background:var(--bg3);border:1px solid var(--grey);border-radius:12px;">
                        <div style="font-size:3rem;font-weight:700;">${calcOverall()}/100</div>
                        <div style="color:var(--text2);">Overall Score</div>
                    </div>
                    <div style="display:flex;gap:0.8rem;justify-content:center;">
                        <button class="btn" onclick="startSession()">▶ New Session</button>
                        <button class="btn btn-o" onclick="hideModal();renderDashboard();">Done</button>
                    </div>`);
            }

            // ===== ANALYTICS =====
            async function renderAnalytics() {
                const sessions = await dbAll('sessions');
                const items = await dbAll('items');
                
                // Collect all unique component names
                const compNames = new Set();
                items.forEach(item => {
                    (item.components||[]).forEach(c => compNames.add(c.name));
                });

                let compOptions = '<option value="">Select...</option>';
                compNames.forEach(n => {
                    compOptions += `<option value="${esc(n)}">${esc(n)}</option>`;
                });

                $('#main-content').innerHTML = `
                    <h2 style="margin-bottom:1.5rem;">Component Analysis</h2>
                    <div class="card">
                        <h3>Component Explorer</h3>
                        <div style="display:flex;gap:0.8rem;margin:1rem 0;">
                            <select class="f-input" id="comp-select" onchange="runAnalysis()" style="flex:2;">
                                ${compOptions}
                            </select>
                            <select class="f-input" id="metric-select" onchange="runAnalysis()" style="flex:1;">
                                <option value="reaction_avg">Reaction</option>
                                <option value="memory_score">Memory</option>
                                <option value="focus_score">Focus</option>
                                <option value="overall_score">Overall</option>
                            </select>
                        </div>
                        <div id="analysis-detail"><p style="color:var(--text2);">Select a component to analyze</p></div>
                    </div>
                    <div class="grid2" style="margin-top:1.5rem;">
                        <div class="card">
                            <h3>Correlation Graph</h3>
                            <div id="graph-area"><p style="color:var(--text2);">Select a component</p></div>
                        </div>
                        <div class="card">
                            <h3>Statistics</h3>
                            <div id="stats-area"><p style="color:var(--text2);">Component stats appear here</p></div>
                        </div>
                    </div>
                    <div class="card" style="margin-top:1.5rem;">
                        <h3>Trend Detection</h3>
                        <div id="trend-area"><p style="color:var(--text2);">Automatic trend analysis</p></div>
                    </div>`;
            }

            async function runAnalysis() {
                const comp = $('#comp-select')?.value;
                const metric = $('#metric-select')?.value;
                if (!comp) return;

                const sessions = await dbAll('sessions');
                const withComp = sessions.filter(s => s.item_names?.includes(comp) && s[metric] != null);
                const withoutComp = sessions.filter(s => !s.item_names?.includes(comp) && s[metric] != null);

                const metricLabels = {
                    reaction_avg: 'Reaction (ms)',
                    memory_score: 'Memory (/20)',
                    focus_score: 'Focus (%)',
                    overall_score: 'Overall Score'
                };

                // Detail
                $('#analysis-detail').innerHTML = `
                    <div class="grid2">
                        <div class="stat"><div class="stat-val" style="font-size:1.4rem;">${withComp.length}</div><div class="stat-lbl">With ${esc(comp)}</div></div>
                        <div class="stat"><div class="stat-val" style="font-size:1.4rem;">${withoutComp.length}</div><div class="stat-lbl">Baseline</div></div>
                    </div>`;

                // Graph
                if (withComp.length >= 2) {
                    drawGraph('graph-area', withComp, metric, comp, metricLabels[metric]);
                } else {
                    $('#graph-area').innerHTML = '<p style="color:var(--text2);">Need 2+ sessions for graph</p>';
                }

                // Stats
                if (withComp.length > 0) {
                    const wAvg = Math.round(withComp.reduce((a,b)=>a+(b[metric]||0),0)/withComp.length);
                    const woAvg = withoutComp.length > 0 ? Math.round(withoutComp.reduce((a,b)=>a+(b[metric]||0),0)/withoutComp.length) : null;
                    const change = woAvg ? Math.round(((wAvg-woAvg)/woAvg)*100) : null;
                    const better = metric === 'reaction_avg' ? (change < 0) : (change > 0);

                    $('#stats-area').innerHTML = `
                        <div style="background:var(--bg3);border:1px solid var(--grey);border-radius:8px;padding:1rem;">
                            <h4>${esc(comp)}</h4>
                            <div class="grid2" style="margin-top:0.5rem;">
                                <div><strong>Sessions:</strong> ${withComp.length}</div>
                                <div><strong>Avg ${metricLabels[metric]}:</strong> ${wAvg}</div>
                                ${woAvg !== null ? `<div><strong>Baseline:</strong> ${woAvg}</div>` : ''}
                                ${change !== null ? `<div style="color:${better?'#4a4':'#a44'}"><strong>Change:</strong> ${change>0?'+':''}${change}%</div>` : ''}
                            </div>
                        </div>`;
                }

                // Trend
                if (withComp.length >= 3) {
                    const sorted = withComp.sort((a,b) => new Date(a.date) - new Date(b.date));
                    const vals = sorted.map(s => s[metric]);
                    const mid = Math.floor(vals.length/2);
                    const first = vals.slice(0,mid).reduce((a,b)=>a+b,0)/mid;
                    const second = vals.slice(mid).reduce((a,b)=>a+b,0)/(vals.length-mid);
                    const pct = ((second-first)/first)*100;
                    const better = metric === 'reaction_avg' ? (pct < 0) : (pct > 0);

                    $('#trend-area').innerHTML = `
                        <p><strong>Direction:</strong> <span style="color:${better?'#4a4':'#a44'}">${better?'Improving':'Declining'}</span> (${pct>0?'+':''}${pct.toFixed(1)}%)</p>
                        <p style="color:var(--text2);margin-top:0.4rem;">Based on ${withComp.length} sessions</p>`;
                } else {
                    $('#trend-area').innerHTML = '<p style="color:var(--text2);">Need 3+ sessions for trends</p>';
                }
            }

            function drawGraph(containerId, sessions, metric, compName, metricLabel) {
                const container = document.getElementById(containerId);
                if (!container) return;

                const sorted = sessions.sort((a,b) => new Date(a.date) - new Date(b.date));
                const vals = sorted.map(s => s[metric]||0);
                const max = Math.max(...vals);
                const min = Math.min(...vals);
                const range = max - min || 1;
                const w = 560, h = 260, pad = 35;
                const pts = vals.map((v,i) => ({
                    x: pad + (i/(vals.length-1))*(w-2*pad),
                    y: h - pad - ((v-min)/range)*(h-2*pad),
                    v, d: new Date(sorted[i].date).toLocaleDateString()
                }));
                const path = pts.map((p,i) => `${i===0?'M':'L'} ${p.x} ${p.y}`).join(' ');

                container.innerHTML = `
                    <div class="graph-box">
                        <svg viewBox="0 0 ${w} ${h}">
                            <line x1="${pad}" y1="${h-pad}" x2="${w-pad}" y2="${h-pad}" stroke="#333" stroke-width="1"/>
                            <line x1="${pad}" y1="${pad}" x2="${pad}" y2="${h-pad}" stroke="#333" stroke-width="1"/>
                            <path d="${path}" fill="none" stroke="#fff" stroke-width="2"/>
                            ${pts.map(p => `<circle cx="${p.x}" cy="${p.y}" r="4" fill="#fff"><title>${p.d}: ${p.v}</title></circle>`).join('')}
                            <text x="${w/2}" y="${h-8}" fill="#666" font-size="11" text-anchor="middle">Sessions →</text>
                        </svg>
                    </div>
                    <p style="color:var(--text2);font-size:0.8rem;margin-top:0.4rem;">${esc(compName)} vs ${metricLabel}</p>`;
            }

            async function exportData() {
                const data = {
                    exportDate: new Date().toISOString(),
                    sessions: await dbAll('sessions'),
                    items: await dbAll('items')
                };
                const blob = new Blob([JSON.stringify(data,null,2)], {type:'application/json'});
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `logostics-${new Date().toISOString().split('T')[0]}.json`;
                a.click();
                URL.revokeObjectURL(url);
                alert('Exported!', 's');
            }

            function esc(str) {
                if (!str) return '';
                const div = document.createElement('div');
                div.textContent = str;
                return div.innerHTML;
            }

            // ===== INIT =====
            async function init() {
                await openDB();
                
                // Nav clicks
                $$('.nav-tab').forEach(tab => {
                    tab.addEventListener('click', () => switchTab(tab.dataset.tab));
                });

                // Modal backdrop close
                $('#modal').addEventListener('click', (e) => {
                    if (e.target === $('#modal')) hideModal();
                });

                // Initial render
                renderDashboard();
            }

            // Expose functions globally
            window.switchTab = switchTab;
            window.showAddItem = showAddItem;
            window.showEditItem = showEditItem;
            window.deleteItem = deleteItem;
            window.addItem = addItem;
            window.editItem = editItem;
            window.startSession = startSession;
            window.beginTests = beginTests;
            window.viewSession = viewSession;
            window.runAnalysis = runAnalysis;
            window.exportData = exportData;
            window.toggleEmojiPicker = toggleEmojiPicker;
            window.toggleEditEmojiPicker = toggleEditEmojiPicker;
            window.pickEmoji = pickEmoji;
            window.handleItemImage = handleItemImage;
            window.handleEditImage = handleEditImage;
            window.addItemTag = addItemTag;
            window.removeItemTag = removeItemTag;
            window.addEditTag = addEditTag;
            window.removeEditTag = removeEditTag;
            window.addCompField = addCompField;
            window.addEditCompField = addEditCompField;
            window.toggleSessionTag = toggleSessionTag;
            window.addSessionTag = addSessionTag;
            window.removeSessionTag = removeSessionTag;
            window.hideModal = hideModal;
            window.renderDashboard = renderDashboard;
            window.esc = esc;

            init().catch(console.error);
        })();
    </script>
</body>
</html>
